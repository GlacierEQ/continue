{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "packages/core/src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@continuedev/core": ["./packages/core/src"],
      "@continuedev/gui": ["./packages/gui/src"]
    }
  },
  "include": ["packages/core/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
